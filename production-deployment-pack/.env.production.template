# ============================================
# Risk Radar - Production Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# ============================================
# DATABASE
# ============================================
MONGO_USER=riskradar
MONGO_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
MONGO_URL=mongodb://riskradar:CHANGE_ME_TO_STRONG_PASSWORD@mongodb:27017/risk_radar?authSource=admin
DB_NAME=risk_radar

# ============================================
# SECURITY - CRITICAL: Change all these!
# ============================================
# JWT Secret - Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# Encryption Key for API tokens - Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_fernet_key

# ============================================
# CORS & DOMAINS
# ============================================
# Your production domain (no trailing slash)
CORS_ORIGINS=https://riskradar.yourdomain.com
BACKEND_URL=https://api.riskradar.yourdomain.com

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_RPM=60
RATE_LIMIT_RPH=1000

# ============================================
# REDIS (for rate limiting & caching)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ============================================
# EMAIL (for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# MONITORING & LOGGING
# ============================================
# Sentry DSN (optional)
SENTRY_DSN=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Environment: development, staging, production
ENVIRONMENT=production

# ============================================
# INTEGRATIONS (optional)
# ============================================
# OpenAI API Key (for AI analysis)
OPENAI_API_KEY=

# ============================================
# SERVER
# ============================================
# Server host (for SSH deployment)
SERVER_HOST=your-server-ip
SERVER_USER=deploy
SERVER_SSH_KEY=# Store in GitHub Secrets, not here!
