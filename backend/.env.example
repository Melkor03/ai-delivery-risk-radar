# ============================================================
# Delivery Risk Radar — Backend Configuration
# Copy this to .env: cp .env.example .env
# ============================================================

# MongoDB (Docker: mongodb://localhost:27017 | Atlas: mongodb+srv://...)
MONGO_URL=mongodb://localhost:27017
DB_NAME=risk_radar

# JWT Secret — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret

# OpenAI — https://platform.openai.com/api-keys
# Leave empty to use rule-based analysis (works without a key)
OPENAI_API_KEY=

# ClickUp — Settings > Apps > Generate API Token (optional)
CLICKUP_API_TOKEN=

# Server
HOST=0.0.0.0
PORT=8001

# Google OAuth (only needed for Google Sheets integration)
# GOOGLE_REDIRECT_URI=http://localhost:8001/api/oauth/sheets/callback
# FRONTEND_URL=http://localhost:3000
